# AutoGreet Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── n8n Webhook URLs ──────────────────────────────────────────
# Get these from your n8n cloud account after creating the workflow
N8N_WEBHOOK_URL=https://your-workspace.app.n8n.cloud/webhook/autogreet-review
N8N_ONBOARD_WEBHOOK_URL=https://your-workspace.app.n8n.cloud/webhook/autogreet-onboard

# ── Admin Security ────────────────────────────────────────────
# Change this to a strong random password — used to access /api/clients and /api/logs
ADMIN_KEY=autogreet-admin-change-this-now

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── Twilio (optional — for direct SMS fallback) ───────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
