# ── Server ─────────────────────────────────────────────────
PORT=3000

# ── Admin Dashboard Password ───────────────────────────────
ADMIN_KEY=autogreet-admin-2026-change-me

# ── n8n Webhooks ───────────────────────────────────────────
# Production webhook URL from Webhook node → "Production URL"
N8N_WEBHOOK_URL=https://wtaanu.app.n8n.cloud/webhook/autogreet-review
N8N_ONBOARD_WEBHOOK_URL=https://wtaanu.app.n8n.cloud/webhook/new-client

# ── MySQL Database (Hostinger) ─────────────────────────────
# Get DB_HOST from: hPanel → Hosting → Manage → look for "MySQL host" or server hostname
# It looks like: srv1234.hstgr.io  OR  sql.hostinger.com
# Enable Remote MySQL in hPanel → Databases → Remote MySQL → add % as allowed host
DB_HOST=srv1234.hstgr.io
DB_PORT=3306
DB_NAME=u719986497_u123456789_aut
DB_USER=anuragini_path
DB_PASS=Anuignite@2109

# ── Twilio (WhatsApp) ──────────────────────────────────────
# From: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

